# Auth
AUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Database — use Neon (https://neon.tech) for production
# DIRECT_URL is the non-pooled connection required by Prisma migrations
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs (create these in your Stripe dashboard)
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=price_starter_...
NEXT_PUBLIC_STRIPE_GROWTH_PRICE_ID=price_growth_...
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_pro_...
NEXT_PUBLIC_STRIPE_BUSINESS_PRICE_ID=price_business_...

# Runway (video generation — https://runwayml.com)
RUNWAYML_API_SECRET=...

# HeyGen (voice dubbing — https://heygen.com)
HEYGEN_API_KEY=...

# ElevenLabs (sound effects — https://elevenlabs.io)
ELEVENLABS_API_KEY=...

# Fal.ai (logo generation — https://fal.ai)
FAL_KEY=...

# PostHog analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
